# === 課金方式 ===
# Max プランの場合: ANTHROPIC_API_KEY を設定しない（claude login の OAuth を使用）
# API 従量課金の場合: 以下を設定
# ANTHROPIC_API_KEY=sk-ant-...

# === Rate Controller ===
# Max プランの場合: RATE_CONTROL_ENABLED=true
# API 従量課金の場合: RATE_CONTROL_ENABLED=false
RATE_CONTROL_ENABLED=true
RATE_COOLDOWN_SECONDS=60
MAX_TASKS_PER_WINDOW=150
RATE_LIMIT_WARN_THRESHOLD=0.1

# === GitHub ===
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-org/your-repo

# === プロジェクトパス（単一リポジトリモード） ===
PROJECT_DIR=/home/user/my-project
WORKTREE_DIR=/home/user/worktrees

# === マルチリポジトリモード（任意） ===
# repos.json を指定すると複数リポジトリを同時管理できます
# 設定すると GITHUB_REPO / PROJECT_DIR / WORKTREE_DIR はフォールバック用になります
# REPOS_JSON_PATH=./repos.json

# === Slack（任意） ===
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# === 運用パラメータ ===
DAILY_BUDGET_USD=10.0
MAX_CONCURRENT=1

# === v3.0 新機能 ===
# Dashboard（リアルタイム Web UI）
DASHBOARD_ENABLED=false
DASHBOARD_PORT=3100

# ToolForge（自律的スキル生成）
TOOLFORGE_ENABLED=false

# Dry Run（デフォルトで全タスクをプレビューモードにする）
DRY_RUN_DEFAULT=false

# Model Router 探索率（0.0-1.0、デフォルト 0.1 = 10%）
EXPLORATION_RATE=0.1
